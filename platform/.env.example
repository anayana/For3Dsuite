# Nach platform/.env kopieren und ausfuellen.

# Oeffentliche Domain (A/AAAA-Record muss auf den Server zeigen; Caddy holt TLS automatisch).
# Fuer lokale Tests ohne Domain: DOMAIN=:80 setzen (dann kein TLS).
DOMAIN=pano.example.org

# Zugang zum Studio (/admin) und zur Studio-API.
# Hash erzeugen:  docker run --rm caddy:2-alpine caddy hash-password --plaintext 'MEIN-PASSWORT'
# Achtung: $-Zeichen im Hash fuer docker compose als $$ escapen!
STUDIO_USER=admin
STUDIO_HASH=$$2a$$14$$REPLACE_ME

# S3-Zugangsdaten fuer die App — werden von init/bootstrap.sh erzeugt und ausgegeben.
S3_ACCESS_KEY=
S3_SECRET_KEY=
